<!DOCTYPE html>
<html>
<head>
  <title>Add New Lecture</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<h1>Add New Lecture</h1>

<form action="/lectures" method="POST">

  <div class="form-row">
    <label>Lecture Title</label>
    <input type="text" name="title" required>
  </div>

  <div class="form-row">
    <label>Speaker First Name</label>
    <input type="text" name="speakerFirst">
  </div>

  <div class="form-row">
    <label>Speaker Last Name</label>
    <input type="text" name="speakerLast">
  </div>

  <div class="form-row">
    <label>Series Title</label>
    <input type="text" name="seriesTitle">
  </div>

  <div class="form-row">
    <label>Duration (minutes)</label>
    <input type="number" name="duration" min="1">
  </div>

  <div class="form-row">
    <label>Genre</label>
    <select name="genre">
      <option value="">(optional)</option>
      <option>Literature</option>
      <option>Economics</option>
      <option>Philosophy</option>
      <option>History</option>
      <option>Science</option>
      <option>Music</option>
      <option>Other</option>
    </select>
  </div>

  <div class="form-row">
    <label>Date Listened</label>
    <input type="date" name="dateListened">
  </div>

  <button type="submit" class="btn">Save Lecture</button>

</form>



</body>
</html>
