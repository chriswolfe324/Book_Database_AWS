<h1>Edit Lecture</h1>

<form action="/lectures/<%= lecture._id %>?_method=PUT" method="POST">

  <div class="form-row">
    <label>Lecture Title</label>
    <input type="text" name="title" value="<%= lecture.title %>" required>
  </div>

  <div class="form-row">
    <label>Speaker First Name</label>
    <input type="text" name="speakerFirst" value="<%= lecture.speakerFirst %>">
  </div>

  <div class="form-row">
    <label>Speaker Last Name</label>
    <input type="text" name="speakerLast" value="<%= lecture.speakerLast %>">
  </div>

  <div class="form-row">
    <label>Series Title</label>
    <input type="text" name="seriesTitle" value="<%= lecture.seriesTitle %>">
  </div>

  <div class="form-row">
    <label>Duration (minutes)</label>
    <input type="number" name="duration" min="1" value="<%= lecture.duration %>">
  </div>

  <div class="form-row">
    <label>Genre</label>
    <select name="genre">
      <option value="">(optional)</option>
      <% ['Literature','Economics','Philosophy','History','Science','Music','Other'].forEach(opt => { %>
        <option value="<%= opt %>" <%= lecture.genre === opt ? 'selected' : '' %>>
          <%= opt %>
        </option>
      <% }) %>
    </select>
  </div>

  <div class="form-row">
    <label>Date Listened</label>
    <input type="date" name="dateListened"
           value="<%= lecture.dateListened ? lecture.dateListened.toISOString().split('T')[0] : '' %>">
  </div>

  <button type="submit" class="btn">Save Changes</button>

</form>