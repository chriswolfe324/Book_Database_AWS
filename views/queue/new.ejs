<%- include('../partials/header') %>

<div class="container">
  <h1>Add to Queue</h1>
  <form action="/queue" method="POST" id="queueForm">
    <label>Type</label>
    <select name="type" id="typeSelect" required>
      <option value="">-- Select Type --</option>
      <option value="Book">Book</option>
      <option value="Audiobook">Audiobook</option>
      <option value="Audio Lecture">Audio Lecture</option>
    </select>

    <div id="dynamicFields"></div>

    <div class="center" style="margin-top:1rem;">
      <button type="submit" class="btn">Add to Queue</button>
    </div>
  </form>
</div>

<script>
  const typeSelect = document.getElementById('typeSelect');
  const dynamicFields = document.getElementById('dynamicFields');

  typeSelect.addEventListener('change', () => {
    const type = typeSelect.value;
    let html = '';

    if (type === 'Book') {
      html = `
        <label>Title</label><input name="title" required>
        <label>Author First Name</label><input name="authorFirstName">
        <label>Author Last Name</label><input name="authorLastName">
        <label>Genre</label><input name="genre">
        <label>Pages</label><input name="pages" type="number">
        <label>Own?</label>
        <select name="own"><option>Yes</option><option>No</option></select>
      `;
    } else if (type === 'Audiobook') {
      html = `
        <label>Title</label><input name="title" required>
        <label>Author First Name</label><input name="authorFirstName">
        <label>Author Last Name</label><input name="authorLastName">
        <label>Genre</label><input name="genre">
        <label>Own?</label>
        <select name="own"><option>Yes</option><option>No</option></select>
      `;
    } else if (type === 'Audio Lecture') {
      html = `
        <label>Lecture Title</label><input name="title" required>
        <label>Speaker Name</label><input name="speakerName">
        <label>Series Title</label><input name="seriesTitle">
        <label>Duration (minutes)</label><input name="duration" type="number">
        <label>Genre</label><input name="genre">
      `;
    }

    dynamicFields.innerHTML = html;
  });
</script>